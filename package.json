        "machine-learning",
        "real-time",
        "censorship",
        "web-safety"
    ],
    "author": "VKrishna04 & Contributors",
    "license": "Apache-2.0",
    "devDependencies": {
        "@playwright/test": "^1.48.0",
        "archiver": "^7.0.1"
    }
}